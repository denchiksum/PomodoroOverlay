{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pomodoro-overlay",
  "version": "0.1.0",
  "identifier": "com.den4iksum.pomodoro-overlay",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5323",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "pomodoro-overlay",
        "width": 340,
        "height": 240,
        "decorations": false,
		"transparent": true,
        "alwaysOnTop": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false,
      "all": true
    }
  }
}